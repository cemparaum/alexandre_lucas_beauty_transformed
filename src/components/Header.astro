---
// src/components/Header.astro
---

<nav class="absolute top-0 left-0 w-full z-50 py-6 border-b border-white/5 bg-transparent">
  <!-- Translucent blurred background layer (separated to prevent containing block constraints on fixed mobile overlays) -->
  <div class="absolute inset-0 bg-[#1C1937]/90 backdrop-blur-md z-10 pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between relative z-50">
    <a class="cursor-hover flex items-center gap-3 group" href={import.meta.env.BASE_URL}>
      <img src={import.meta.env.BASE_URL + "images/ArteLogo.png"} alt="ALEXANDRE LUCAS" class="h-10 md:h-12 w-auto object-contain drop-shadow-md transition-transform duration-700 group-hover:scale-105 mix-blend-lighten" />
      <img src={import.meta.env.BASE_URL + "images/nomelogo.png"} alt="Beauty Transformed" class="h-7 md:h-8 w-auto object-contain drop-shadow-md transition-transform duration-700 group-hover:scale-105 mix-blend-lighten" />
    </a>
    
    <!-- Premium Links (Desktop) -->
    <div class="hidden md:flex items-center gap-5 lg:gap-8">
      <a class="cursor-hover text-[11px] font-heading font-semibold uppercase tracking-[0.2em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#experiencia"}>A Experiência</a>
      <a class="cursor-hover text-[11px] font-heading font-semibold uppercase tracking-[0.2em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#diferenciais"}>Diferenciais</a>
      <a class="cursor-hover text-[11px] font-heading font-semibold uppercase tracking-[0.2em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "servicos"}>Serviços</a>
      <a class="cursor-hover text-[11px] font-heading font-semibold uppercase tracking-[0.2em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#resultados"}>Resultados</a>
      <a class="cursor-hover text-[11px] font-heading font-semibold uppercase tracking-[0.2em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "sobre"}>Sobre</a>
      <a class="cursor-hover text-[11px] font-heading font-semibold uppercase tracking-[0.2em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#contato"}>Contato</a>
    </div>

    <!-- Hamburger Button (Mobile Only) -->
    <button id="hamburger-btn" class="cursor-hover md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 focus:outline-none relative z-50" aria-label="Toggle Menu">
      <span class="w-6 h-[1.5px] bg-silverSteel transition-all duration-300 origin-center" id="bar1"></span>
      <span class="w-6 h-[1.5px] bg-silverSteel transition-all duration-300 origin-center" id="bar2"></span>
      <span class="w-6 h-[1.5px] bg-silverSteel transition-all duration-300 origin-center" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile Menu Panel (Full screen overlay with premium translucent glassmorphism) -->
  <div id="mobile-menu-panel" class="fixed inset-0 bg-[#1C1937]/90 backdrop-blur-xl z-40 transition-all duration-500 -translate-y-4 opacity-0 pointer-events-none overflow-y-auto">
    <div id="mobile-menu-content" class="px-8 pt-32 pb-12 flex flex-col items-center justify-start gap-8 min-h-screen w-full">
      <a class="mobile-nav-link text-[16px] font-heading font-semibold uppercase tracking-[0.25em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#experiencia"}>A Experiência</a>
      <a class="mobile-nav-link text-[16px] font-heading font-semibold uppercase tracking-[0.25em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#diferenciais"}>Diferenciais</a>
      <a class="mobile-nav-link text-[16px] font-heading font-semibold uppercase tracking-[0.25em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "servicos"}>Serviços</a>
      <a class="mobile-nav-link text-[16px] font-heading font-semibold uppercase tracking-[0.25em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#resultados"}>Resultados</a>
      <a class="mobile-nav-link text-[16px] font-heading font-semibold uppercase tracking-[0.25em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "sobre"}>Sobre</a>
      <a class="mobile-nav-link text-[16px] font-heading font-semibold uppercase tracking-[0.25em] text-silverSteel hover:text-white transition-colors duration-300" href={import.meta.env.BASE_URL + "#contato"}>Contato</a>
    </div>
  </div>
</nav>

<script>
  // Mobile Hamburger Menu Cycle & Click-outside Logic
  const initMenu = () => {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const menuPanel = document.getElementById('mobile-menu-panel');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    if (!hamburgerBtn || !menuPanel) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      if (hamburgerBtn) hamburgerBtn.classList.add('open');
      
      if (menuPanel) {
        menuPanel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        menuPanel.classList.remove('opacity-0', '-translate-y-4', 'pointer-events-none');
      }
    }

    function closeMenu() {
      isOpen = false;
      if (hamburgerBtn) hamburgerBtn.classList.remove('open');
      
      if (menuPanel) {
        menuPanel.classList.add('opacity-0', '-translate-y-4', 'pointer-events-none');
        menuPanel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      }
    }

    hamburgerBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close when clicking any menu link
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    // Close when clicking empty area (backdrop behavior)
    menuPanel.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === menuPanel || target.id === 'mobile-menu-content') {
        closeMenu();
      }
    });

    // Close when clicking anywhere else on the document
    document.addEventListener('click', (e) => {
      if (isOpen) {
        const targetNode = e.target as Node;
        if (!menuPanel.contains(targetNode) && !hamburgerBtn.contains(targetNode)) {
          closeMenu();
        }
      }
    });
  };

  // Run on DOM load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMenu);
  } else {
    initMenu();
  }
</script>

<style>
  /* Hamburger button animation classes */
  #hamburger-btn #bar1,
  #hamburger-btn #bar2,
  #hamburger-btn #bar3 {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #hamburger-btn.open #bar1 {
    transform: translateY(8px) rotate(45deg);
  }
  
  #hamburger-btn.open #bar2 {
    opacity: 0;
  }
  
  #hamburger-btn.open #bar3 {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>
