<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes marquee-reverse {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  .animate-marquee-reverse {
    animation: marquee-reverse 50s linear infinite;
  }
  .hover-pause:hover {
    animation-play-state: paused;
  }
  /* Elegant gradient masks for the edges of the marquee */
  .mask-edges {
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  
  /* Lightbox active states */
  #lightbox.active {
    opacity: 1;
    pointer-events: auto;
  }
  #lightbox.active #lightbox-img {
    transform: scale(1);
  }
</style>

<script>
  const cards = document.querySelectorAll('.portfolio-card');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxClose = document.getElementById('lightbox-close');
  const container = document.getElementById('carousel-container');

  // 1. Lightbox functionality
  let isDragging = false;

  if (lightbox && lightboxImg instanceof HTMLImageElement) {
    cards.forEach(card => {
      card.addEventListener('click', () => {
        // Prevent opening lightbox if user was dragging
        if (isDragging) return;
        
        const imgSrc = card.getAttribute('data-img');
        if (imgSrc) {
          lightboxImg.src = imgSrc;
          lightbox.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(() => {
        lightboxImg.src = '';
      }, 300);
    };

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === lightboxClose || (lightboxClose && lightboxClose.contains(e.target as Node))) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('active')) {
        closeLightbox();
      }
    });
  }

  // 2. Interactive Carousel (Drag + Auto-scroll)
  if (container) {

    // Drag to scroll logic
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let startDragX = 0;
    const dragThreshold = 5;

    container.addEventListener('mousedown', (e) => {
      isDown = true;
      isDragging = false;
      startDragX = e.clientX;
      startX = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
    });

    container.addEventListener('mouseleave', () => {
      isDown = false;
    });

    container.addEventListener('mouseup', () => {
      isDown = false;
      // Keep isDragging true for a split second to prevent immediate click event
      setTimeout(() => {
        isDragging = false;
      }, 50);
    });

    container.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      
      // Determine if dragging based on move threshold
      if (Math.abs(e.clientX - startDragX) > dragThreshold) {
        isDragging = true;
      }
      
      const x = e.pageX - container.offsetLeft;
      const walk = (x - startX) * 1.5; // speed multiplier
      container.scrollLeft = scrollLeft - walk;
    });

    // 3. Infinite loop wrapping
    container.addEventListener('scroll', () => {
      const halfWidth = container.scrollWidth / 2;
      if (container.scrollLeft >= halfWidth) {
        container.scrollLeft -= halfWidth;
      } else if (container.scrollLeft <= 0) {
        container.scrollLeft += halfWidth;
      }
    });

    // 4. Smooth Auto-scroll with hover/touch pause
    let autoScrollActive = true;
    const scrollSpeed = 0.6; // pixels per frame

    function step() {
      if (container && autoScrollActive && !isDown) {
        container.scrollLeft += scrollSpeed;
      }
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);

    // Pause auto-scroll on hover or touch
    container.addEventListener('mouseenter', () => {
      autoScrollActive = false;
    });

    container.addEventListener('mouseleave', () => {
      if (!isDown) {
        autoScrollActive = true;
      }
    });

    container.addEventListener('touchstart', () => {
      autoScrollActive = false;
    });

    container.addEventListener('touchend', () => {
      // Resume auto-scroll after a short delay of inactivity
      setTimeout(() => {
        if (!isDown) autoScrollActive = true;
      }, 2500);
    });
  }
</script>
