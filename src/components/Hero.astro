<script>
  // Add animation class after load
  window.addEventListener('load', () => {
    setTimeout(() => {
      const hero = document.querySelector('#hero');
      if (hero) hero.classList.add('hero-revealed');
    }, 100);

    // Generate Gold Dust Particles
    const dustContainer = document.getElementById('gold-dust');
    if (dustContainer) {
      const particleCount = window.innerWidth < 768 ? 10 : 25; // Greatly reduced for performance
      for (let i = 0; i < particleCount; i++) {
        const particle = document.createElement('div');
        particle.className = 'absolute rounded-full bg-champagneGold'; // Removed mix-blend-screen
        
        // Randomize sizes and positions
        const size = Math.random() * 2 + 1;
        particle.style.width = `${size}px`;
        particle.style.height = `${size}px`;
        particle.style.left = `${Math.random() * 100}%`;
        particle.style.top = `${Math.random() * 100}%`;
        
        // Soft opacity, no box-shadow to improve performance
        particle.style.opacity = (Math.random() * 0.3 + 0.1).toString();
        
        // Floating animation with random delays and durations
        particle.style.animation = `float-particle ${Math.random() * 15 + 15}s linear ${Math.random() * -20}s infinite alternate`;
        particle.style.willChange = 'transform';
        
        dustContainer.appendChild(particle);
      }
    }
  });

  // Background Slideshow Cycle Logic
  const slides = document.querySelectorAll('#hero-slideshow .slide-wrapper');
  let currentSlide = 0;
  
  if (slides.length > 0) {
    setInterval(() => {
      slides[currentSlide].classList.remove('active');
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add('active');
    }, 6000); // Cross-fade every 6 seconds
  }
</script>

<style>
  /* Elegant soft fade-in synced with wave */
  .split-line span {
    display: block;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), 
                transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  .hero-revealed .split-line span {
    opacity: 1;
    transform: translateY(0);
  }

  /* Ripple Effect Styles - GPU Accelerated Glow */
  .ripple-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 100%;
    height: 100%;
    border-radius: 50%;
    
    /* Beautiful glowing wave effect */
    border: 3px solid rgba(212, 178, 111, 0.3);
    box-shadow: 0 0 60px rgba(212, 178, 111, 0.15), inset 0 0 30px rgba(212, 178, 111, 0.1);
    
    opacity: 0;
    will-change: transform, opacity; /* Forces GPU hardware acceleration */
    animation: ripple-expand 10.5s cubic-bezier(0.1, 0.5, 0.7, 1) infinite;
  }

  @keyframes ripple-expand {
    0% {
      transform: translate(-50%, -50%) scale(0);
      opacity: 0.8;
      /* Notice: We DO NOT animate border-width here to prevent CPU repaints */
    }
    100% {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 0;
    }
  }

  /* Slideshow Styles with GPU Acceleration & Ken Burns Zoom transitions */
  .slide-wrapper {
    opacity: 0;
    transition: opacity 2s ease-in-out;
    pointer-events: none;
  }
  
  .slide-wrapper.active {
    opacity: 1;
    pointer-events: auto;
  }
  
  /* Horizontal gradient mask on desktop to fade individual columns into the background */
