    <div class="text-center mb-20 reveal">
      <div class="inline-flex items-center justify-center gap-3 mb-6">
        <div class="w-8 h-[1px] bg-silverSteel"></div>
        <span class="text-[10px] font-mono uppercase tracking-[0.4em] text-silverSteel font-bold">O Antes e o Depois</span>
        <div class="w-8 h-[1px] bg-silverSteel"></div>
      </div>
      <h2 class="font-serif text-5xl md:text-7xl text-white tracking-tighter">
        Resultados <span class="italic text-white/50 font-light">Inegáveis</span>
      </h2>
    </div>

    <!-- Video Carousel (Infinite Marquee) -->
    <div class="relative overflow-hidden w-full py-4 mask-edges">
      <div class="flex w-max animate-marquee-reverse hover-pause">
        
        <!-- SET 1 -->
        <div class="flex gap-6 pr-6">
          <!-- Video 1 -->
          <div class="w-[85vw] md:w-[400px] shrink-0 group relative aspect-[9/16] rounded-[2rem] overflow-hidden border border-white/10 hover:border-champagneGold/50 transition-all duration-700 cursor-pointer">
            <img src="https://images.pexels.com/photos/3993212/pexels-photo-3993212.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Transformação 1" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-60 group-hover:opacity-100" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent pointer-events-none"></div>
            
            <!-- Play Button -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-20 h-20 rounded-full bg-black/40 backdrop-blur-md border border-white/30 flex items-center justify-center group-hover:bg-champagneGold group-hover:border-champagneGold transition-all duration-500 group-hover:scale-110 shadow-[0_0_40px_rgba(212,178,111,0)] group-hover:shadow-[0_0_40px_rgba(212,178,111,0.6)]">
              <span class="iconify w-8 h-8 text-white ml-1" data-icon="lucide:play"></span>
            </div>

            <div class="absolute bottom-8 left-8 right-8 pointer-events-none">
              <h3 class="font-serif text-2xl text-white mb-2 drop-shadow-md">Loiro Assinatura</h3>
